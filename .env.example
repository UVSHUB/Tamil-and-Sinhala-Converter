# ==============================================================================
# Sinhala ↔ Tamil Voice Translator - Environment Variables Configuration Blueprint
# Copy this file to '.env' and populate with your credentials. DO NOT commit '.env'.
# ==============================================================================

# ------------------------------------------------------------------------------
# Google Gemini API Settings
# ------------------------------------------------------------------------------
# Obtain your Gemini API Key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# The Gemini model to target for real-time live audio translation
# e.g., gemini-2.0-flash-exp (or whichever model is active for the Live API)
GEMINI_MODEL=gemini-2.0-flash-exp

# ------------------------------------------------------------------------------
# Backend Service Settings (FastAPI)
# ------------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Frontend & CORS Settings (Vite / React)
# ------------------------------------------------------------------------------
# Allowed origins for CORS (comma-separated for multiple origins)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# Public environment variable for React to connect to the backend WebSocket
VITE_WS_URL=ws://localhost:8000/ws/translate

# ------------------------------------------------------------------------------
# Nginx / Reverse Proxy settings
# ------------------------------------------------------------------------------
NGINX_PORT=80
